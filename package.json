{
  "name": "@stdiobus/skills",
  "version": "1.0.1",
  "description": "MCP Agentic Skills — structured, validated, machine-readable skills for AI agents delivered over Model Context Protocol via stdio Bus",
  "private": false,
  "type": "commonjs",
  "sideEffects": false,
  "main": "out/dist/index.mjs",
  "module": "out/dist/index.mjs",
  "types": "out/tsc/index.d.ts",
  "exports": {
    ".": {
      "types": "./out/tsc/index.d.ts",
      "import": "./out/dist/index.mjs",
      "default": "./out/dist/index.mjs"
    },
    "./mcp-server": {
      "import": "./out/dist/mcp-server.mjs",
      "default": "./out/dist/mcp-server.mjs"
    },
    "./skills-manifest": {
      "default": "./agent-skills/skills-manifest.json"
    },
    "./skills/*/SKILL.md": {
      "default": "./agent-skills/*/SKILL.md"
    },
    "./skills/*/references/*": {
      "default": "./agent-skills/*/references/*"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build:js": "node esbuild.config.mjs",
    "build:types": "tsc -p tsconfig.types.json",
    "build": "npm run clean && npm run build:js && npm run build:types",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "validate": "tsx agent-skills/scripts/validate-skills.ts",
    "test": "jest --maxWorkers=50% --forceExit --detectOpenHandles",
    "test:ci": "jest --maxWorkers=2 --forceExit --detectOpenHandles --ci --reporters=default",
    "test:watch": "jest --watch --maxWorkers=25%",
    "test:verbose": "jest --maxWorkers=50% --forceExit --detectOpenHandles --verbose",
    "test:coverage": "jest --maxWorkers=50% --forceExit --detectOpenHandles --coverage",
    "clean": "rm -rf out",
    "build:pack": "npm run build && npm pack --pack-destination out/",
    "ci": "npm run typecheck && npm run validate && npm run test:ci",
    "verify:package": "tsx agent-skills/scripts/verify-package/verify-package.ts",
    "prepublishOnly": "npm run clean && npm run build && npm run test"
  },
  "bin": {
    "mcp-skills": "out/dist/mcp-server.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@stdiobus/node": "^2.0.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@aws-sdk/client-eventbridge": "^3.1041.0",
    "@stdiobus/mcp-agentic": "1.1.2",
    "@types/aws-lambda": "^8.10.161",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.19.39",
    "@worktif/runtime": "0.5.0-beta.4",
    "esbuild": "^0.28.0",
    "fast-check": "^3.15.0",
    "jest": "^29.7.0",
    "openai": "^6.35.0",
    "ts-jest": "^29.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.4.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/agent-skills/__tests__"
    ],
    "testMatch": [
      "**/*.test.ts"
    ],
    "collectCoverageFrom": [
      "agent-skills/**/*.ts",
      "!agent-skills/__tests__/**",
      "!agent-skills/scripts/**",
      "!agent-skills/**/*.d.ts"
    ],
    "coverageDirectory": "out/coverage",
    "coverageReporters": [
      "text",
      "lcov",
      "html",
      "json-summary"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    },
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "tsconfig": {
            "module": "commonjs",
            "esModuleInterop": true
          }
        }
      ]
    }
  },
  "keywords": [
    "agent-skills",
    "skills",
    "model-context-protocol",
    "mcp",
    "agentic",
    "agentic-lambda",
    "llm-agent",
    "ai-documentation",
    "worktif",
    "worktif-runtime",
    "aws-lambda",
    "serverless",
    "aws-cdk",
    "typescript",
    "event-driven",
    "dependency-injection",
    "cold-start",
    "sqs",
    "sns",
    "eventbridge",
    "kinesis",
    "dynamodb",
    "microservices",
    "skill-manifest",
    "stdiobus",
    "acp",
    "json-rpc",
    "ndjson"
  ],
  "author": {
    "name": "Raman Marozau",
    "email": "raman@worktif.com"
  },
  "contributors": [
    {
      "name": "Raman Marozau",
      "email": "raman@worktif.com"
    }
  ],
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/stdiobus/skills/issues"
  },
  "homepage": "https://github.com/stdiobus/skills#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stdiobus/skills.git",
    "directory": "packages/skills"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "packageManager": "yarn@1.22.22",
  "files": [
    "out/dist/**/*.mjs",
    "out/tsc/**/*.d.ts",
    "agent-skills/**/SKILL.md",
    "agent-skills/**/references/**",
    "agent-skills/skills-manifest.json",
    "!agent-skills/scripts/**",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "restricted",
    "registry": "https://registry.npmjs.org/"
  }
}
