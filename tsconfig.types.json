{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "out/tsc",
    "rootDir": "agent-skills",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true
  },
  "include": [
    "agent-skills/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "out",
    "test"
  ]
}